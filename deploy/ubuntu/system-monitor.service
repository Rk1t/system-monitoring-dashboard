[Unit]
Description=System Monitor central backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=system-monitor
Group=system-monitor
WorkingDirectory=/opt/system-monitor/backend
EnvironmentFile=-/etc/system-monitor.env
ExecStart=/opt/system-monitor/backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
